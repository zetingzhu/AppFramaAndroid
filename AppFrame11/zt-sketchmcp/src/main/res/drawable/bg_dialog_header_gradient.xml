<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog header gradient: Red (#FF3B13) → Orange-Red (#FF7254) → Warm White (#FFF3E8)
     With top rounded corners 30dp -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#FF3B13"
        android:centerColor="#FF7254"
        android:endColor="#FFF3E8" />
    <corners
        android:topLeftRadius="30dp"
        android:topRightRadius="30dp" />

</shape>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/llTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#333333" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="城市"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- 搜索栏区域 -->
    <LinearLayout
        android:id="@+id/llSearchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#F5F5F5"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@id/llTopBar">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="#999999" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="搜索城市"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="14sp" />

        <!-- 清除搜索内容按钮 -->
        <ImageView
            android:id="@+id/ivClearSearch"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:padding="2dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:visibility="gone"
            app:tint="#999999" />

        <!-- 搜索取消按钮 (键盘弹起时显示) -->
        <TextView
            android:id="@+id/tvCancelSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="取消"
            android:textColor="#333333"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 左侧列表与右侧索引父容器 -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/llBottomInput"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSearchBar">

        <!-- 使用 RVStickyHeaderLayout 包裹 RecyclerView 实现悬停效果 -->
        <com.trade.zt_kotlinmcp.rvweigit.RVStickyHeaderLayout
            android:id="@+id/stickyHeaderLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginEnd="32dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="24dp"
                tools:listitem="@android:layout/simple_list_item_1" />

        </com.trade.zt_kotlinmcp.rvweigit.RVStickyHeaderLayout>

        <!-- 右侧自定义字母索引条 -->
        <com.trade.zt_kotlinmcp.ui.AlphabetIndexView
            android:id="@+id/alphabetIndexView"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />
    </FrameLayout>

    <!-- 底部无选项可手动输入区域 -->
    <LinearLayout
        android:id="@+id/llBottomInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 包裹 EditText 和 X 号的带圆角灰色背景框 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="#F5F5F5"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <EditText
                android:id="@+id/etManualInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="无选项可手动填写"
                android:singleLine="true"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/ivClearManual"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:visibility="gone"
                app:tint="#999999" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:backgroundTint="#3B5998"
            android:text="确定"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
